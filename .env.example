# Required — Anthropic
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Required — hackathon-shared read-only Postgres
# (event-day info-pack credential; replica on Render)
DATABASE_URL=postgresql://user:pass@host/dbname

# Optional — HTTP Basic Auth (enabled when both are set)
# AUTH_USERNAME=reviewer
# AUTH_PASSWORD=choose-a-strong-password
